import sys

def main():
    s = sys.stdin.readline().strip()

    last_seen = {}
    left = 0
    max_len = 0

    for right, ch in enumerate(s):
        if ch in last_seen and last_seen[ch] >= left:
            left = last_seen[ch] + 1
        last_seen[ch] = right
        current_len = right - left + 1
        if current_len > max_len:
            max_len = current_len

    print(max_len)

if __name__ == "__main__":
    main()
